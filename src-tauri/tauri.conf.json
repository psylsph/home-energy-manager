{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Home Energy Manager",
  "mainBinaryName": "givenergy-local",
  "version": "0.59.0",
  "identifier": "com.givenergy.local",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:desktop && npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Home Energy Manager",
        "width": 950,
        "height": 970,
        "x": 0,
        "y": 0,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "enableGTKAppId": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "rpm"],
    "resources": {
      "../dist": "dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "librsvg2-2"
        ],
        "provides": ["giv-energy-local"],
        "conflicts": ["giv-energy-local"],
        "replaces": ["giv-energy-local"],
        "files": {
          "/usr/share/givenergy-local/dist": "../dist"
        }
      },
      "rpm": {
        "provides": ["GivEnergy-Local"],
        "conflicts": ["GivEnergy-Local"],
        "obsoletes": ["GivEnergy-Local"],
        "files": {
          "/usr/share/givenergy-local/dist": "../dist"
        }
      }
    }
  }
}
