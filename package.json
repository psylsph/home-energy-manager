{
  "name": "givenergy-local",
  "private": true,
  "version": "0.37.1",
  "description": "Local monitoring and control for GivEnergy solar/battery inverters",
  "author": "Stuart Harding",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/psylsph/home-energy-manager.git"
  },
  "bugs": {
    "url": "https://github.com/psylsph/home-energy-manager/issues"
  },
  "homepage": "https://github.com/psylsph/home-energy-manager#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:md": "markdownlint . --ignore node_modules --ignore src-tauri/target --ignore AUDIT.md --ignore REGISTER_AUDIT.md --ignore test-results",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:local": "playwright test --config playwright.local.config.ts",
    "test:local:headed": "playwright test --config playwright.local.config.ts --headed"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "markdownlint-cli": "^0.49.0",
    "tailwindcss": "^4.1.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "react-router": "^7.6.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^2.15.3",
    "zustand": "^5.0.4"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.1.0",
    "@rolldown/binding-darwin-x64": "^1.0.3",
    "@rolldown/binding-linux-x64-gnu": "^1.0.3",
    "@rolldown/binding-win32-x64-msvc": "^1.0.3",
    "@tailwindcss/oxide-darwin-arm64": "^4.3.0",
    "@tailwindcss/oxide-darwin-x64": "^4.3.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.3.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.1",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lightningcss-darwin-x64": "^1.32.0",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  }
}
